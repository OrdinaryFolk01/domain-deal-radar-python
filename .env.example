APP_NAME=Domain Deal Radar
DATABASE_URL=sqlite:///./data/radar.db
CRAWLER_CONCURRENCY=5
CRAWLER_TIMEOUT_SECONDS=8
SEARCH_ENGINES=360,toutiao
DEFAULT_SITE_INDEX_ENGINES=baidu,sogou,360,bing,toutiao,google
SITE_INDEX_MIN_COUNT=10000
SEARCH_TIMEOUT_SECONDS=12

# 邮件收发配置。建议使用邮箱服务商的授权码，不要填写网页登录密码。
# QQ IMAP：MAIL_RECEIVE_HOST=imap.qq.com, MAIL_RECEIVE_PORT=993, MAIL_RECEIVE_USE_SSL=true
# QQ POP3：MAIL_RECEIVE_HOST=pop.qq.com, MAIL_RECEIVE_PORT=995, MAIL_RECEIVE_USE_SSL=true
MAIL_RECEIVE_PROTOCOL=imap
MAIL_RECEIVE_HOST=
MAIL_RECEIVE_PORT=993
MAIL_RECEIVE_USE_SSL=true
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=false
SMTP_USE_SSL=true
